# Copy to .env (or set in your host's dashboard). All optional locally —
# development needs none of these.

# --- Production (gaijinhunterjp.com on Render) ---
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string     # python3 -c 'import secrets;print(secrets.token_hex(32))'
BASE_URL=https://gaijinhunterjp.com              # canonical origin (apex).
                                                 # Use https://www.gaijinhunterjp.com instead ONLY if
                                                 # you choose www as canonical — pick one, never both.
JAPAN_JOBS_DB=/var/data/jobs.db                  # SQLite on Render's persistent disk

# --- Local overrides (rarely needed) ---
# HOST=0.0.0.0
# PORT=5000
